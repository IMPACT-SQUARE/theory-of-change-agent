meetings/*.txt

# Generated skill output (rendered PDMs are produced at runtime)
**/out/

# Node
node_modules/

# Private source PDFs (real project documents — kept outside the repo)
docs/*_PDM.pdf
# Build artifacts
*.zip
# Internal scratch (not for the public repo)
/STATUS-*.md
/산출물.md
.omc/
